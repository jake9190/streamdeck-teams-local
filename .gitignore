# Build outputs published into the plugin package.
# Everything in the package folder is generated EXCEPT manifest.json, imgs/ and ui/.
com.local.msteams-local.sdPlugin/*
!com.local.msteams-local.sdPlugin/manifest.json
!com.local.msteams-local.sdPlugin/imgs/
!com.local.msteams-local.sdPlugin/ui/

# .NET build artifacts
bin/
obj/
[Dd]ebug/
[Rr]elease/
*.user
*.suo
project.lock.json
artifacts/

# Distribution archives
dist/
*.streamDeckPlugin

# Node (Elgato CLI)
node_modules/

# IDE / OS
.vs/
.vscode/
.idea/
*.swp
Thumbs.db
.DS_Store

# Logs
logs/
*.log
